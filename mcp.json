{
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": [
        "--yes",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_DB_PATH": "./.memory/memory.db"
      }
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "--add-host=host.docker.internal:host-gateway",
        "mcp-server-github"
      ]
    },
    "sqlite": {
      "command": "docker",
      "args": [
        "run",
        "--add-host=host.docker.internal:host-gateway",
        "-v",
        "./.memory:/var/lib/data",
        "mcp-server-sqlite"
      ]
    }
  }
}
